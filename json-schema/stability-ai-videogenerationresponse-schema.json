{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/VideoGenerationResponse",
  "title": "VideoGenerationResponse",
  "type": "object",
  "properties": {
    "video": {
      "type": "string",
      "description": "Base64-encoded video data when Accept header is set to application/json."
    },
    "finish_reason": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "CONTENT_FILTERED"
      ],
      "description": "The reason the generation finished."
    },
    "seed": {
      "type": "integer",
      "description": "The seed used for generation."
    }
  }
}