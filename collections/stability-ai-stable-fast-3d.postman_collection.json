  "item": [
    {
      "id": "27f11af6-7d89-47a5-88e8-822711262b3a",
      "name": "3D Generation",
      "description": {
        "content": "Generate textured 3D mesh assets from single input images using the Stable Fast 3D model.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "d0ee4f02-c173-4de9-9daa-6b55f0fc8d43",
          "name": "Generate a 3D model from an image",
          "request": {
            "name": "Generate a 3D model from an image",
            "description": {
              "content": "Generates a textured, UV-unwrapped 3D mesh from a single input image. The model interprets the 2D image and produces a 3D object with geometry and texture suitable for real-time rendering applications. Output is returned as a GLB file containing the mesh and texture data.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v2beta",
                "3d",
                "stable-fast-3d"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "model/gltf-binary"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "description": "(Required) The input image of an object to convert into a 3D model. Best results are achieved with images of single objects on a clean background."
                },
                {
                  "key": "texture_resolution",
                  "value": "1024",
                  "type": "text",
                  "description": "The resolution of the generated texture in pixels. Higher values produce more detailed textures but increase file size and processing time. (This can only be one of 512,1024,2048)"
                },
                {
                  "key": "foreground_ratio",
                  "value": "0.85",
                  "type": "text",
                  "description": "The ratio of the foreground object to the total image size. Used to control how much of the image is treated as the object versus background during 3D reconstruction."
                },
                {
                  "key": "remesh",
                  "value": "none",
                  "type": "text",
                  "description": "The remeshing algorithm to apply to the generated mesh. Triangle and quad remeshing produce cleaner topology suitable for animation and further editing. (This can only be one of none,triangle,quad)"
                }
              ]
            }
          },
